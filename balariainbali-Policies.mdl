{UTF-8}
Larval control effectiveness=0.33
	~	Dmnl
	~		|

Fraction of GDP for prevention=0.005
	~	Dmnl [0,0.3]
	~		|

bed net coverage=MIN (prevention funding,Net allocation share)/Cost for full coverage
	~	Dmnl
	~		|

Bed net efficiency=0.7
	~	Dmnl [0,1]
	~		|

prevention funding=GDP per Capita*Fraction of GDP for prevention
	~	USD/person
	~		|

Transmission Probability=0.1 * (1-(vaccine coverage*Vaccine efficiency))
	~	Dmnl [0,1]
	~	Probability of transmission from mosquito to human per bite [0.1,0.5]
	|

Biting rate=10.1 * 1-(bed net coverage*Bed net efficiency)
	~	1/Month [0,30]
	~	Effective contact rate per mosquito per month [10,30]
	|

Cost for full coverage=10
	~	USD/person [2,30]
	~		|

Vaccine efficiency=0.8
	~	Dmnl
	~		|

Net allocation share=0.5
	~	Dmnl [0,1]
	~		|

Policy larval control active=0
	~	Dmnl
	~		|

vaccine coverage=MIN ( prevention funding,Net allocation share) / Cost for full coverage
	~	Dmnl
	~		|

Mosquito Reproduction Rate=1.5 * (1-(Larval control effectiveness*Policy larval control active\
		))
	~	1/Month [0,5]
	~	Maximum mosquito reproduction rate [3,10]
	|

GDP per Capita= INTEG (Economic Growth - Economic Decay,
		 800)
	~	USD/person
	~	Gross Domestic Product per capita [500,5000]
	|

GDP ref=GDP per Capita/GDP scale
	~	Dmnl
	~		|

GDP scale=1
	~	USD/person
	~		|

Births=Total human population * Birth rate * (1 - (Total human population/Human Carrying Capacity\
		))
	~	person/Month
	~	Number of new births
	|

"Maximum Sustainable GDP (GDPmax)"=4500
	~	USD/person
	~		|

Cost per case=100
	~	USD/(person*Month)
	~	Economic cost per malaria case per month [50,500]
	|

Drag time constant=164
	~	Month
	~		|

Economic Loss from Malaria=(Infected Symptomatic * Cost per case) / Total human population
	~	USD/(Month*person)
	~		|

Economic Decay=Economic Loss from Malaria + "Non-Malaria Economic Loss"
	~	(USD/person)/Month
	~	Economic loss from malaria per capita
	|

Growth rate=0.015 * EXP(-GDP ref/ 5000)
	~	1/Month
	~	Economic growth rate per capita [0.002,0.01]
	|

Healthcare Quality Index=0.05 + 0.75 / (1 + EXP(-0.00375 * (GDP ref - 1440)))
	~	Dmnl
	~	Healthcare quality index (0-1) based on GDP index
	|

Human Carrying Capacity=2 * 10^7
	~	person
	~		|

"Non-Malaria Economic Loss"=(GDP per Capita/Drag time constant)* (GDP per Capita / "Maximum Sustainable GDP (GDPmax)"\
		)^4
	~	USD/(Month*person)
	~		|

Malaria deaths per 1000=Malaria deaths/Total human population * 1000
	~	1/Month
	~		|

infection rate per 1000=Infection Rate/Total human population*1000
	~	1/Month
	~		|

Infection Rate=Transmission Probability * Biting rate * (Infectious Mosquitoes / Total mosquito population\
		) * Susceptible Humans
	~	person/Month
	~	New human infections per month
	|

Base Duration of Infection=0.5
	~	Month
	~	Average duration of malaria infection without treatment [0.5,2]
	|

Base Malaria Mortality=0.05
	~	1/Month
	~	Malaria mortality rate per infected person [0.01,0.20]
	|

Birth rate=0.005
	~	1/Month
	~	Human birth rate per capita [0.003,0.015]
	|

Human deaths=Susceptible Humans * Natural mortality rate
	~	person/Month
	~	Non-malaria deaths from susceptible population
	|

Duration of Immunity=6
	~	Month [6,10]
	~	Average duration of immunity after recovery [6,24]
	|

Economic Growth=GDP per Capita * Growth rate
	~	(USD/person)/Month
	~	Increase in GDP per capita
	|

Exposed Mosquitoes= INTEG (Mosquito Infection Rate-Latent Progression-Mosquito deaths II\
		,
		100000)
	~	Mosquito
	~	Mosquitoes infected but not yet infectious [1000,1e6]
	|

Infected Symptomatic= INTEG (Infection Rate - Malaria deaths- Recovery Rate - Human deaths II\
		,
		2.5e+06)
	~	person
	~	Symptomatically infected humans [1000,1e6]
	|

Infectious Mosquitoes= INTEG (Latent Progression-Mosquito deaths III,
		8e+06)
	~	Mosquito
	~	Infectious mosquitoes capable of transmission [1000,1e6]
	|

Latent Progression=Exposed Mosquitoes / Mosquito Incubation Period
	~	Mosquito/Month
	~	Progression from exposed to infectious state
	|

Malaria deaths=Infected Symptomatic * Base Malaria Mortality * (1 - Healthcare Quality Index\
		)
	~	person/Month
	~	Malaria-induced deaths per month
	|

Mosquito Births=Total mosquito population * Mosquito Reproduction Rate * (1-Total mosquito population\
		/Mosquito Carrying Capacity)
	~	Mosquito/Month
	~	New mosquito births with density dependence
	|

Mosquito Carrying Capacity=1e+08
	~	Mosquito
	~	Maximum sustainable mosquito population [1e6,1e8]
	|

Mosquito deaths=Susceptible Mosquitoes / Mosquito life expectancy
	~	Mosquito/Month
	~	Deaths of susceptible mosquitoes
	|

Mosquito deaths II=Exposed Mosquitoes / Mosquito life expectancy
	~	Mosquito/Month
	~	Deaths of exposed mosquitoes
	|

Mosquito deaths III=Infectious Mosquitoes / Mosquito life expectancy
	~	Mosquito/Month
	~	Deaths of infectious mosquitoes
	|

Mosquito Incubation Period=0.4
	~	Month
	~	Time from infection to infectiousness in mosquitoes [0.2,0.6]
	|

Mosquito Infection Rate=Trans Prob Human to Mosquito * Biting rate * (Infected Symptomatic\
		/ Total human population) * Susceptible Mosquitoes
	~	Mosquito/Month
	~	New mosquito infections per month
	|

Mosquito life expectancy=1.5
	~	Month [0,3]
	~	Average mosquito lifespan [0.33,1]
	|

Human deaths II=Infected Symptomatic * Natural mortality rate
	~	person/Month
	~	Non-malaria deaths from infected population
	|

Human deaths III=Recovered Humans * Natural mortality rate
	~	person/Month
	~	Non-malaria deaths from recovered population
	|

Natural mortality rate=0.00069
	~	1/Month
	~	Natural human mortality rate [0.0005,0.001]
	|

Recovered Humans= INTEG (Recovery Rate-Human deaths III-Waning Immunity,
		0)
	~	person
	~	Humans with temporary immunity [0,1e7]
	|

Recovery Rate=Infected Symptomatic * (1 + Healthcare Quality Index) / Base Duration of Infection
	~	person/Month
	~	Recovery from infection to immune state
	|

Susceptible Humans= INTEG (Births + Waning Immunity - Infection Rate - Human deaths,
		1.8e+07)
	~	person
	~	Humans susceptible to infection [1e6,1e8]
	|

Susceptible Mosquitoes= INTEG (Mosquito Births-Mosquito deaths-Mosquito Infection Rate\
		,
		3e+07)
	~	Mosquito
	~	Mosquitoes susceptible to infection [1e6,1e8]
	|

Total human population=Infected Symptomatic + Recovered Humans + Susceptible Humans
	~	person
	~	Total human population
	|

Total mosquito population=Susceptible Mosquitoes + Infectious Mosquitoes + Exposed Mosquitoes
	~	Mosquito
	~	Total mosquito population
	|

Trans Prob Human to Mosquito=0.3
	~	Dmnl
	~	Probability of transmission from human to mosquito per bite [0.1,0.5]
	|

Waning Immunity=Recovered Humans / Duration of Immunity
	~	person/Month
	~	Loss of immunity over time
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2000
	~	Month
	~	The final time for the simulation (10 years).
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Month [0,?]
	~	The time step for the simulation.
	|

